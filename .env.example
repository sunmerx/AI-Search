# ── 部署 ─────────────────────────────────────────────────
# GitHub Pages 子路径（CI 自动设置，本地留空）
# NEXT_PUBLIC_BASE_PATH=/AI-Search

# ── 数据源 ───────────────────────────────────────────────
# auto (默认) | local (构建用) | mock (离线演示)
DATA_SOURCE=auto

# ── AI 能力（可选）───────────────────────────────────────
# 不设则跳过 AI 点评/必读，其余功能不受影响
# DEEPSEEK_API_KEY=sk-xxx

# AI 问答代理地址（Cloudflare Worker，见 worker/ 目录）
# NEXT_PUBLIC_ASK_AI_URL=https://your-worker.workers.dev

# ── 爬虫配置 ─────────────────────────────────────────────
# GITHUB_TOKEN=ghp_xxx
GITHUB_TOPICS=llm,ai-agent,generative-ai,rag,llmops,agents,diffusion-models,multimodal
CRAWL_DAYS=30
GITHUB_PER_TOPIC=10
RSS_MAX_PER_FEED=20
HN_MIN_POINTS=40
CRAWL_TIMEOUT_MS=15000
# CRAWL_ARXIV=1
